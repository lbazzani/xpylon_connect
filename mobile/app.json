{
  "expo": {
    "name": "Xpylon Connect",
    "slug": "xpylon-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "xpylonconnect",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#444444",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xpylon.connect",
      "infoPlist": {
        "NSCameraUsageDescription": "Xpylon Connect uses the camera for video calls and photo sharing",
        "NSPhotoLibraryUsageDescription": "Xpylon Connect accesses the gallery to send photos in chat",
        "NSMicrophoneUsageDescription": "Xpylon Connect uses the microphone for voice and video calls"
      }
    },
    "android": {
      "package": "com.xpylon.connect",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#444444"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-image-picker",
      "expo-localization"
    ]
  }
}
