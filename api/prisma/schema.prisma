generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  phone            String    @unique
  email            String?   @unique
  firstName        String
  lastName         String
  bio              String?
  role             String?
  industry         String?
  companyId        String?
  embedding        Unsupported("vector(1536)")?
  profileCompleted Boolean   @default(false)
  isAdmin          Boolean   @default(false)
  lastSeenAt       DateTime?
  isOnline         Boolean   @default(false)
  createdAt        DateTime  @default(now())

  company              Company?              @relation(fields: [companyId], references: [id])
  connectionsSent      Connection[]          @relation("Requester")
  connectionsReceived  Connection[]          @relation("Addressee")
  invitesSent          Invite[]
  messages             Message[]
  conversationMembers  ConversationMember[]
  fcmTokens            FcmToken[]
  messageReceipts      MessageReceipt[]
  opportunities           Opportunity[]
  opportunityInterests    OpportunityInterest[]
  opportunitySaved        OpportunitySaved[]
  reviewedOpportunities   Opportunity[]         @relation("ReviewedBy")
}

model Company {
  id    String @id @default(uuid())
  name  String
  users User[]
}

model Connection {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  requester User @relation("Requester", fields: [requesterId], references: [id])
  addressee User @relation("Addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Invite {
  id          String       @id @default(uuid())
  senderId    String
  phoneTarget String
  token       String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  sender User @relation(fields: [senderId], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Conversation {
  id              String              @id @default(uuid())
  type            ConversationType
  topic           ConversationTopic   @default(GENERAL)
  name            String?
  opportunityName String?
  opportunityId   String?
  createdById     String
  createdAt       DateTime            @default(now())

  opportunity Opportunity?       @relation(fields: [opportunityId], references: [id])
  members     ConversationMember[]
  messages    Message[]
  calls       Call[]
}

enum ConversationType {
  DIRECT
  OPPORTUNITY_GROUP
}

enum ConversationTopic {
  GENERAL
  PROFILING
  OPPORTUNITY_CREATION
  OPPORTUNITY_DISCUSSION
  SUGGESTIONS
}

model ConversationMember {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  type           MessageType  @default(TEXT)
  replyToId      String?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  conversation Conversation     @relation(fields: [conversationId], references: [id])
  sender       User             @relation(fields: [senderId], references: [id])
  replyTo      Message?         @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]        @relation("MessageReplies")
  attachments  Attachment[]
  receipts     MessageReceipt[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

model MessageReceipt {
  id          String    @id @default(uuid())
  messageId   String
  userId      String
  deliveredAt DateTime  @default(now())
  readAt      DateTime?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId])
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  objectId  String
  fileName  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  message       Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  storageObject StorageObject @relation(fields: [objectId], references: [id])

  @@index([messageId])
}

model StorageObject {
  id           String   @id @default(uuid())
  bucket       String   @default("attachments")
  key          String   @unique
  mimeType     String
  size         Int
  originalName String
  // Per le immagini: varianti generate (thumbnail, medium, large)
  variants     Json?    // { "thumbnail": "key", "medium": "key", "large": "key" }
  uploadedById String
  createdAt    DateTime @default(now())

  attachments Attachment[]
}

model Call {
  id             String    @id @default(uuid())
  conversationId String
  callerId       String
  type           CallType
  status         CallStatus @default(RINGING)
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ONGOING
  ENDED
  MISSED
  DECLINED
}

model Opportunity {
  id           String                @id @default(uuid())
  authorId     String
  title        String
  description  String
  type         OpportunityType
  tags         String[]
  visibility   OpportunityVisibility
  commMode     CommMode
  status       OpportunityStatus     @default(ACTIVE)
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  author        User                  @relation(fields: [authorId], references: [id])
  reviewedBy    User?                 @relation("ReviewedBy", fields: [reviewedById], references: [id])
  interests     OpportunityInterest[]
  savedBy       OpportunitySaved[]
  conversations Conversation[]

  @@index([authorId])
  @@index([status])
  @@index([type])
}

enum OpportunityType {
  PARTNERSHIP
  DISTRIBUTION
  INVESTMENT
  SUPPLY
  ACQUISITION
  OTHER
}

enum OpportunityVisibility {
  INVITE_ONLY
  NETWORK
  OPEN
}

enum CommMode {
  PRIVATE
  GROUP
}

enum OpportunityStatus {
  ACTIVE
  UNDER_REVIEW
  PAUSED
  CLOSED
  REJECTED
}

model OpportunityInterest {
  id            String         @id @default(uuid())
  opportunityId String
  userId        String
  status        InterestStatus @default(PENDING)
  createdAt     DateTime       @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@index([opportunityId])
  @@index([userId])
}

enum InterestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model OpportunitySaved {
  opportunityId String
  userId        String
  savedAt       DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@id([opportunityId, userId])
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
